# Bismillah Product Intelligence Platform — Gemini Proxy Server (Fase 4, Paso 4)
#
# Copia este archivo a server/.env (o exporta estas variables de otra forma)
# y NUNCA commitees el archivo real — .env y .env.* ya están en .gitignore.
# Uso: GEMINI_API_KEY=<tu-key> node server/gemini-proxy-server.js
# (o carga server/.env con tu propio mecanismo antes de arrancar el proceso;
# este servidor no incluye un cargador de .env para no añadir una dependencia
# nueva al proyecto — lee únicamente process.env).

# Obligatoria. Se obtiene en Google AI Studio (https://aistudio.google.com/).
# Nunca se envía al frontend ni se acepta desde la petición del cliente.
GEMINI_API_KEY=

# Opcionales — ver comentarios en server/gemini-proxy-server.js para los
# valores por defecto de cada una.
GEMINI_MODEL=
PORT=
GEMINI_TIMEOUT_MS=

# Sin definir: solo se permiten orígenes http://localhost / http://127.0.0.1
# (desarrollo local). Un despliegue real DEBE definir esta variable.
ALLOWED_ORIGIN=
